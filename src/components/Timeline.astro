---
interface TimelineEntry {
  slug: string;
  title: string;
  subtitle: string;
  lapse: string;
  bodyHtml: string;
  pointLabel: string;
  background?: string;
}

interface Props {
  id: string;
  sectionTitle: string;
  entries: TimelineEntry[];
  indicatorIcon?: string;
}

const { id, sectionTitle, entries, indicatorIcon = '✈️' } = Astro.props;
---

<section class="vtl-section" id={id} data-animate>
  <h2 class="vtl-title" data-animate-child>{sectionTitle}</h2>

  <div class="vtl-container">
    <div class="vtl-line" aria-hidden="true">
      <div class="vtl-line-fill" data-vtl-line={id}></div>
    </div>

    {entries.map((entry, i) => (
      <article
        class={`vtl-item ${i % 2 === 0 ? 'vtl-item--left' : 'vtl-item--right'}`}
        data-animate-child
      >
        <div class="vtl-node" aria-hidden="true">
          <span class="vtl-node-icon">{indicatorIcon}</span>
        </div>
        <div class="vtl-card">
          <span class="vtl-card-date">{entry.lapse}</span>
          <h3 class="vtl-card-title">{entry.title}</h3>
          <p class="vtl-card-subtitle">{entry.subtitle}</p>
          <div class="vtl-card-body" set:html={entry.bodyHtml} />
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  @import '../styles/components/timeline.css';
</style>
