---
interface Props {
  label: string;
  icon: string;
  description: string;
  featured?: boolean;
}

const { label, icon, description, featured = false } = Astro.props;
---

<div class={`bento-card ${featured ? 'bento-card--featured' : ''}`} data-animate-child>
  <div class="bento-card-icon">
    <i class={icon} aria-hidden="true"></i>
  </div>
  <h3 class="bento-card-label">{label}</h3>
  <p class="bento-card-desc">{description}</p>
</div>
