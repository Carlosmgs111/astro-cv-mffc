---
interface Props {
  label: string;
  level: number;
}

const { label, level } = Astro.props;

const radius = 46;
const circumference = 2 * Math.PI * radius;
const offset = circumference - (level / 100) * circumference;
---

<div class="skill-card" data-animate-child>
  <div class="skill-progress">
    <svg viewBox="0 0 100 100">
      <circle class="skill-progress-bg" cx="50" cy="50" r={radius} />
      <circle
        class="skill-progress-fill"
        cx="50"
        cy="50"
        r={radius}
        stroke-dasharray={circumference}
        stroke-dashoffset={offset}
      />
    </svg>
    <span class="skill-progress-text">{level}%</span>
  </div>
  <span class="skill-label">{label}</span>
</div>
