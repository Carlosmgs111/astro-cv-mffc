---
interface ContactLink {
  name: string;
  label: string;
  url: string;
  icon: string;
}

interface Props {
  contacts: ContactLink[];
}

const { contacts } = Astro.props;

const sections = [
  { id: 'hero', icon: 'fa-solid fa-house', label: 'Inicio' },
  { id: 'experiences', icon: 'fa-solid fa-briefcase', label: 'Experiencia' },
  { id: 'formations', icon: 'fa-solid fa-graduation-cap', label: 'Formación' },
  { id: 'skills', icon: 'fa-solid fa-chart-bar', label: 'Habilidades' },
  { id: 'contact', icon: 'fa-solid fa-address-book', label: 'Contacto' },
];

const iconMap: Record<string, string> = {
  whatsapp: 'fa-brands fa-whatsapp',
  linkedin: 'fa-brands fa-linkedin',
  email: 'fa-solid fa-envelope',
};
---

<nav class="navbar" id="navbar" aria-label="Navegación principal">
  <button class="navbar-toggle" id="navbar-toggle" aria-label="Abrir menú" aria-expanded="false">
    <span class="navbar-toggle-bar"></span>
    <span class="navbar-toggle-bar"></span>
    <span class="navbar-toggle-bar"></span>
  </button>

  <div class="navbar-panel" id="navbar-panel">
    <ul class="navbar-links" role="list">
      <li class="navbar-indicator" id="navbar-indicator" aria-hidden="true"></li>
      {sections.map((s) => (
        <li>
          <a class="navbar-link" href={`#${s.id}`} data-section={s.id} title={s.label}>
            <i class={s.icon} aria-hidden="true"></i>
            <span class="navbar-link-label">{s.label}</span>
          </a>
        </li>
      ))}
    </ul>
    <div class="navbar-contact">
      {contacts.map((c) => (
        <a
          href={c.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`navbar-contact-link ${c.icon}`}
          aria-label={c.name}
        >
          <i class={iconMap[c.icon] || 'fa-solid fa-link'} aria-hidden="true"></i>
        </a>
      ))}
    </div>
  </div>
</nav>

<style>
  @import '../styles/components/navbar.css';
</style>
