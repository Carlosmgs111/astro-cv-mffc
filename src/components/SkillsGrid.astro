---
import SkillCard from './SkillCard.astro';

interface SkillData {
  label: string;
  icon: string;
  description: string;
}

interface Props {
  skills: SkillData[];
}

const { skills } = Astro.props;
---

<section class="skills-section" id="skills" data-animate>
  <h2 class="skills-title" data-animate-child>Habilidades</h2>
  <div class="bento-grid">
    {skills.map((skill, i) => (
      <SkillCard
        label={skill.label}
        icon={skill.icon}
        description={skill.description}
        featured={i === 0}
        colorIndex={i}
      />
    ))}
  </div>
</section>

<style>
  @import '../styles/components/skills.css';
</style>
